// Prisma Schema for SmartClass Embedded Systems
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model EmbeddedSystem {
  id          String   @id @default(cuid())
  name        String
  location    String
  classroom   String?
  description String?
  status      String   @default("active")
  ipAddress   String?
  macAddress  String?  @unique
  deviceId    String?  @unique
  lastSeen    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  sensors     Sensor[]
  powerUsage  PowerUsage[]
  commands    Command[]
  heatingSchedules HeatingSchedule[]
  
  @@map("embedded_systems")
}

model Sensor {
  id               String   @id @default(cuid())
  name             String
  type             String
  unit             String?
  currentValue     Float?
  minValue         Float?
  maxValue         Float?
  threshold        Float?
  status           String   @default("online")
  embeddedSystemId String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  embeddedSystem   EmbeddedSystem @relation(fields: [embeddedSystemId], references: [id], onDelete: Cascade)
  readings         SensorReading[]
  
  @@map("sensors")
  @@index([embeddedSystemId])
  @@index([type])
}

model SensorReading {
  id        String   @id @default(cuid())
  sensorId  String
  value     Float
  timestamp DateTime @default(now())
  
  sensor    Sensor   @relation(fields: [sensorId], references: [id], onDelete: Cascade)
  
  @@map("sensor_readings")
  @@index([sensorId, timestamp(sort: Desc)])
}

model PowerUsage {
  id               String   @id @default(cuid())
  embeddedSystemId String
  voltage          Float?
  current          Float?
  power            Float
  energy           Float?
  timestamp        DateTime @default(now())
  
  embeddedSystem   EmbeddedSystem @relation(fields: [embeddedSystemId], references: [id], onDelete: Cascade)
  
  @@map("power_usage")
  @@index([embeddedSystemId, timestamp(sort: Desc)])
}

model Command {
  id               String   @id @default(cuid())
  embeddedSystemId String
  type             String
  payload          Json
  status           String   @default("pending")
  sentAt           DateTime @default(now())
  executedAt       DateTime?
  response         Json?
  
  embeddedSystem   EmbeddedSystem @relation(fields: [embeddedSystemId], references: [id], onDelete: Cascade)
  
  @@map("commands")
  @@index([embeddedSystemId, status])
  @@index([sentAt(sort: Desc)])
}

model HeatingSchedule {
  id               String   @id @default(cuid())
  embeddedSystemId String
  season           String   // spring, summer, fall, winter
  month            Int?     // 1-12 (optional, for monthly override)
  startTime        String   // HH:mm format - زمان شروع
  endTime          String   // HH:mm format - زمان پایان
  targetTemperature Float   // دمای مطلوب
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  embeddedSystem   EmbeddedSystem @relation(fields: [embeddedSystemId], references: [id], onDelete: Cascade)
  
  @@map("heating_schedules")
  @@index([embeddedSystemId, season, month])
  @@unique([embeddedSystemId, season, month])
}
