// Prisma Schema for SmartClass Embedded Systems
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DeviceStatus {
  active
  inactive
  maintenance
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("user") // user, admin
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model EmbeddedSystem {
  id          String   @id @default(cuid())
  name        String
  location    String
  classroom   String?
  description String?
  status      DeviceStatus @default(active)
  ipAddress   String?
  macAddress  String?  @unique
  deviceId    String?  @unique
  lastSeen    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deviceReadings DeviceReading[]
  powerUsage  PowerUsage[]
  commands    Command[]
  heatingSchedules HeatingSchedule[]
  alarms Alarm[]

  @@map("embedded_systems")
}

model DeviceReading {
  id               String   @id @default(cuid())
  embeddedSystemId String
  temperature      Float?
  humidity         Float?
  light            Float?
  presence         Float?
  currentConsumption Float?
  timestamp        DateTime @default(now())
  
  embeddedSystem   EmbeddedSystem @relation(fields: [embeddedSystemId], references: [id], onDelete: Cascade)
  
  @@map("device_readings")
  @@index([embeddedSystemId, timestamp(sort: Desc)])
}

model PowerUsage {
  id               String   @id @default(cuid())
  embeddedSystemId String
  voltage          Float?
  current          Float?
  power            Float
  energy           Float?
  timestamp        DateTime @default(now())
  
  embeddedSystem   EmbeddedSystem @relation(fields: [embeddedSystemId], references: [id], onDelete: Cascade)
  
  @@map("power_usage")
  @@index([embeddedSystemId, timestamp(sort: Desc)])
}

model Command {
  id               String   @id @default(cuid())
  embeddedSystemId String
  type             String
  payload          Json
  status           String   @default("pending")
  sentAt           DateTime @default(now())
  executedAt       DateTime?
  response         Json?
  
  embeddedSystem   EmbeddedSystem @relation(fields: [embeddedSystemId], references: [id], onDelete: Cascade)
  
  @@map("commands")
  @@index([embeddedSystemId, status])
  @@index([sentAt(sort: Desc)])
}

model HeatingSchedule {
  id               String   @id @default(cuid())
  embeddedSystemId String
  season           String   // spring, summer, fall, winter
  month            Int      // 1-12 (required - specific month of the season)
  weekdays         String   @default("0,1,2,3,4,5,6") // Days of week: 0=Sunday, 1=Monday, ..., 6=Saturday
  startTime        String   // HH:mm format - زمان شروع
  endTime          String   // HH:mm format - زمان پایان
  targetTemperature Float   // دمای مطلوب
  targetLuminance  Int      @default(50) // Target light level 0-100
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  embeddedSystem   EmbeddedSystem @relation(fields: [embeddedSystemId], references: [id], onDelete: Cascade)
  
  @@map("heating_schedules")
  @@index([embeddedSystemId, season, month])
}

model Alarm {
  id               String   @id @default(cuid())
  embeddedSystemId String
  triggeredAt      DateTime @default(now())
  resolvedAt       DateTime?
  
  embeddedSystem   EmbeddedSystem @relation(fields: [embeddedSystemId], references: [id], onDelete: Cascade)
  
  @@map("alarms")
  @@index([embeddedSystemId, triggeredAt(sort: Desc)])
  @@index([embeddedSystemId, resolvedAt])
}
